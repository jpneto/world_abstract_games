(option "Selection Mode" <Mode> args:{<forSkirting> <destinations> }
 {
  (item "Move or Place"
   <("Skirting" (sites Empty))>
   <("SkirtSites" (player))>
   "Selection Mode: As described in the rules:
   Move by selecting a pod placement, or a pod to move followd by its destination."
  )
  (item "Moves limited to non-placement"
   <("Skirting" (difference (sites Empty) ("PlacementSitesFor" (mover))))>
   <("DestinationsOnlyforSkirting" (player))>
   "Selection Mode: Movement Restricted:
   Move by selecting a pod placement, or a pod to move --
   but only to a destination that cannot be reached by placement.
   
   Note: This option is increase AI depth by reducing its choices. It rarely affects play, because is better to place to a space than to move there, except when you need to simultaneously open a movement channel and move to a location where a placement cannot be made. 
   
   "
  )
//  (item "Destination then Source"
//   <("DestinationSkirting")>
//   <("DestinationsOnlyforSkirting" (player))>
//   "Selection Mode: Destination First:
//   Move by selecting destination and then source if the destination cannot /be reached by placement."
//  )
 }
)

