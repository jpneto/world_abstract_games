// Pods - Single-Action version of Natal Seas.
 
(define "OpponentOf" (- 3 #1))

(define "PiecesOf" (sites Occupied by:(player #1)))
(define "IsAPieceOf" (= #1 (who at:(to))))

(define "SitesInfluenceOfFor"
 (difference
  (sites Around (sites Occupied by:All) <Board:dir>)
  (forEach
   (players All if:(!= (player) #2))
   (sites Around (sites Occupied by:All) //(player #2)) 
    <Board:dir>
    if:(and
     (is Empty (to))    
     (!=
      #1
      (-
       (count Pieces of:#2 in:(sites Around (to) <Board:dir>))
       (count Pieces of:(player) in:(sites Around (to) <Board:dir>))
)))))))

(define "NeighborCountAt"
 (size Array (array (sites Around #1 <Board:dir>)))
)

(define "NaturalTerritoryOf" // Pieces; majority surrounded sites; and pairs of half surrounded sites
 (union 
  {
   (sites Occupied by:(player #1))
   (forEach
    (sites Around (sites Occupied by:All) <Board:dir>)
    if:(or
     (<
      ("NeighborCountAt" (site))
      (* 2 (count Pieces of:#1 in:(sites Around (site) <Board:dir>)))
     )
     
     (and
      (=
       ("NeighborCountAt" (site))
       (* 2 (count Pieces of:#1 in:(sites Around (site) <Board:dir>)))
      )
      (< 0
       (size Array
        (array
         (sites Around (site) <Board:dir>
          if:(and
           (is Empty (to))
           (=
            ("NeighborCountAt" (to))
            (* 2 (count Pieces of:#1 in:(sites Around (to) <Board:dir>)))
     )))))))
   ))
  }
))

 
(define "SkirtSites"
 (sites Around
  (union
   (sites Occupied by:(player (mover))) 
   (sites Occupied by:(player #1))
  )
  <Board:dir>
))

(define "DestinationsOnlyforSkirting"  // but need to check accessibility - not used right now.
 (union
  {
   (intersection ("SitesInfluenceOfFor" 0 #1) ("SkirtSites" #1)) // "NeutralSites"  
   (difference ("SitesInfluenceOfFor" -1 #1) (sites Around (var "LF") <Board:dir>))
  }
))  
// -------------------------------------------
/// Skirting

(define "MaintainsContact"  // The original location must be treated as empty.
 (not
  (no Pieces
   in:(difference
    (intersection
     (sites Around (from) <Board:dir>
      if:(or (= (mover) (who at:(to))) (= #1 (who at:(to))))
     )
     (sites Around (to) <Board:dir>
      if:(or (= (mover) (who at:(to))) (= #1 (who at:(to))))
    ))
    (sites {(var "LF")})
))))

(define "HasEnoughInfluenceWhileSkirting"
 (>=
  (+ 
   (if   // For the moving piece without double counting at origin
    (is In (var "LF") (sites Around (from) <Board:dir>))
    0 
    1
   ) 
   (count Pieces of:(mover)
    in:(intersection (sites State 0) (sites Around (from) <Board:dir>))
  ))
  (count Pieces of:#1
   in:(intersection (sites State 0) (sites Around (from) <Board:dir>))
)))

(define "CanSkirtThereForAnyGiven" // for mover during move
 (and 
  {
   (!= #1 (mover)) // bug fix, influence is based on nonmovers
   (is Empty (from))
   ("MaintainsContact" #1)
   ("HasEnoughInfluenceWhileSkirting" #1)
  }
))

(define "CanMultiPlayerSkirt"
 (is In (to)
  (forEach of:(sites {1..<Player:count>})
   (if
    (!= Infinity
     (count Steps <Board:dir>
      (step <Board:dir>
       (to
        if:("CanSkirtThereForAnyGiven" (site)) // site === player index here
      ))
      #2
      #1 // switch direction to test
    ))
    (sites {(to)})
))))

(define "Skirting"
 (forEach Piece 
  (do
   (set Var "LF" (from))
   next:(move
    (from)
    (to
     #1 // (sites Empty)
     if:(and
      {
       (!= (to) (from))
       ("CanMultiPlayerSkirt" (var "LF") (to))
      }
))))))

(define "PlacementSitesFor"
 (difference
  (sites Around (sites Occupied by:All) <Board:dir>)
  (forEach
   (players All if:(!= (player) #1))
   (sites Around (sites Occupied by:All) //(player #1)) 
    <Board:dir>
    if:(and
     (is Empty (to))    
     (<=
      (count Pieces of:#1 in:(sites Around (to) <Board:dir>))
      (count Pieces of:(player) in:(sites Around (to) <Board:dir>))
))))))
 
(define "DestinationSkirting"
 (move Select
  (from 
   (difference
    (sites To ("Skirting" (sites Empty)))
    ("PlacementSitesFor" (mover))
  ))
  (to
   (sites Occupied by:Mover)
   if:(is In (from)
    (sites To
     (do
      (set Var "LF" (to))
      next:(move
       (from (var "LF"))
       (to
        (sites Empty)
        if:(and
         {
          (!= (to) (from))
          ("CanMultiPlayerSkirt" (var "LF") (to))
         }
  )))))))
  (then
   (fromTo
    (from (last To))
    (to
     (last From)
)))))

(define "Placement"
 (priority
  {
   (if 
    (> <Player:count> (count Pieces All))
    (if
     (or (no Pieces of:1) (is Mover (who at:(last To))))
     (move Add (piece (mover))
      (to
       (sites Empty)
       if:(<
        (count Steps (to) (sites Outer))
        (count Steps (centrePoint) (sites Outer))
       )
       (apply (set Var "StartRadius" (count Steps (to) (sites Outer))))
     ))
     (move Add  (piece (mover))
      (to
       (sites Empty) 
       if:(>= 1
        (abs
         (- 
          (count Steps (to) (sites Outer))
          (var "StartRadius")
   )))))))
   (move Add  (piece (mover))
    (to 
     ("PlacementSitesFor" (mover))
   ))
  }
))

//---------------------------------------
// Main routine
//---------------------------------------
  
(game "Natal Seas - Pods"
 (players <Player:count>)
 (equipment
  {
   (board <Board:size> use:Vertex)
   (piece "Disc" Each maxState:15)  // was 11
  }
 )
 (rules 
  (play
   (do
    (remove (intersection (sites Occupied by:Mover) (sites State 1))) 
    next:(or
     {
      ("Placement")
      (<Mode:forSkirting>) // "DestinationSkirting" "Skirting"
     }
    ) 
    (then (if (< 2 (counter)) ("SetExtendedTerritoryForAll"))) // ("SetScores")) 
  ))
  (end 
   {
    (forEach Player  
     if:(and
      ("IsLargestActivePLayer" Player)
      (or
       ("HasMoreThanHalfTheSpacesAvailableToTheNextLargestActivePlayer")
       (and
        {
         (!= (player) (mover))
         (<= (count Vertices) (* <Player:count> (count Pieces Mover)))
         ("IsLargestActivePLayer" Mover)
         (= 0           // mover has no Empty skirting mover available 
          (count Sites
           in:(intersection (sites Empty) (sites To ("Skirting" (sites Empty))))
         )) 
        }
     )))
     (result Player Win) // this exposes A/B bug if 2 win sumultaneously with different scores...
    )
    (if
     (or
      (=
       (count Vertices)
       (count Pieces All)
      )
      (= 1
       (size Array (players All if:(is Active (player))))
     ))
     (byScore {(score P1 (value Player P1)) (score P2 (value Player P2)) <Player:score>})
    ) 
    (if 
     (<=
      (count Vertices)
      (* 2 (value Player Mover))
     )
     (result Mover Win)
    ) 
   }  
)))

//-------------------------------
// End Conditions
  
(define "PieceCountOfLargestActiveNonMover" 
 (max
  (results // for each player... Hack
   from:(forEach
    (sites {1..<Player:count>})
    if:(and
     {
      (!= (player) (site))
      (is Active (site))
     }
   )) 
   to:(from)
   (count Pieces of:(from))
)))
(define "IsLargestActivePLayer"
 (>= (count Pieces #1) ("PieceCountOfLargestActiveNonMover"))
)

(define "HasMoreThanHalfTheSpacesAvailableToTheNextLargestActivePlayer"
 (<=
  (+ (count Sites in:(sites Empty)) ("PieceCountOfLargestActiveNonMover")) 
  (count Pieces Player)
))

//-----------------------------
// Territory Filling

(define "PivotSites"
 (intersection
  (sites Around (from) <Board:dir>)
  (sites Around (to) <Board:dir>)
))

(define "HasAPivot"
 (< 0
  (+
   // Pieces and Non-player territory sites
   (count Pieces All
    in:(difference
     ("PivotSites")
     (intersection  //to exclude territory markers of the blocking player
      (sites Occupied by:Player) 
      (sites State 1)
   )))
   // sites under consideration
   (count Sites
    in:(intersection
     {
      ("PivotSites")
      (sites (values Remembered))
      (sites Empty) // to prevent double counting of Non-player territory
     }
)))))

(define "IsConnectedToOthersAtBecause"
 (!= Infinity
  (count Steps <Board:dir>
   #2 // step definition
   #1
   ("SitesOthersPiecesAndTerritory")
)))

(define "OpponentInfluenceAtFrom"
 (and
  {
   (is Empty (from))
   (#1                // i.e. = or >
    (size Array
     (array
      (sites Around (from) <Board:dir> 
       if:(or
        (is In (to) (sites (values Remembered)))
        (not (is Empty (to))) 
    ))))
    (* 2
     (count Pieces Player
      in:(intersection (sites State 0) (sites Around (from) <Board:dir>))
   )))
  }
))

(define "OpponentCanStepFrom" 
 (and
  (!= (player) (who at:(to)))
  (or
   ("OpponentInfluenceAtFrom" >)
   (and
    ("OpponentInfluenceAtFrom" =)
    (or
     ("HasAPivot")
     (< 2 <Player:count>)
)))))

(define "OpponentReachableSites"
 (forEach
  (difference (sites Empty) (sites (values Remembered)))
  if:(!= Infinity
   (count Steps
    (step (to if:("OpponentCanStepFrom")))
    (site)
    (difference
     (sites Occupied by:All)
     (sites Occupied by:Player)
)))))

(define "FindNonTerritoryFor" 
 (seq
  {
   (set Var "TC" -2 )
   (while
    (< (var "TC") (count Sites in:(sites (values Remembered))))
    (seq
     {
      (set Var "TC" (count Sites in:(sites (values Remembered))))
      (forEach Site ("OpponentReachableSites")
       (remember Value (site) unique:True)
      )
     }
   ))
  }
))

(define "SitesOwnPlayersPiecesAndTerritory"
 (sites Occupied by:Player)
)

(define "SitesOthersPiecesAndTerritory"
 (difference
  (sites Occupied by:All)
  (sites Occupied by:Player)
))

(define "CountAroundOf"
 (count Sites 
  in:(sites Around #1 <Board:dir>
   if:(is In (to)  
    #2
))))

(define "SetTerritoryFor" 
 (add
  (piece (player))
  (to
   (difference (sites Empty) (sites (values Remembered)))       
   if:(!= Infinity
    (count Steps <Board:dir>
     (step <Board:dir>
      (to
       if:(and
        (or (is Empty (from)) (= (player) (who at:(to))))
        (>= 
         ("CountAroundOf" (from) "SitesOwnPlayersPiecesAndTerritory") 
         ("CountAroundOf" (from) "SitesOthersPiecesAndTerritory")
     ))))
     (site)
     (sites Occupied by:(player (player)))
   ))
   (apply (set State at:(to) 1))
)))

(define "SetExtendedTerritoryForAll"
 (forEach Player
  (seq
   {
    (forget Value All)
    ("FindNonTerritoryFor")
    ("SetTerritoryFor")
    (set Value Player (count Pieces Player))
    (set Score Player ("HeuristicScoreOf" (player)))
   }
)))

