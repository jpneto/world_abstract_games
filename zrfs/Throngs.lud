// Anti-cycling: 
// 1. A pure move cannot move to a potential placement site. This means that a pure move cannot return to where it came from without assistance of another moving piece of either player,
// and the other piece must be one that hasn't moved, or else has been assisted. -
// Thus ultimately, there can be no pure movement cycle.
// 2. A caturing piece may not move to where it inturn may be captured.



(define "ValueMoverAtSite"
 (if
  (> 0 <Strength:type> )
  0  
  (* <Grid:boostFactor> (+ <Strength:amount> (* <Grid:siteInfluence>  <Strength:type> )))
))

(define "ValueMoverAroundSite" <Grid:boostFactor> )
(define "ValueEnemyAtSite" (- 0 ("ValueMoverAtSite")))
(define "ValueEnemyAroundSite" (- 0 ("ValueMoverAroundSite")))
(define "NeighborCountOfAt" 
 (+
  {
   (* "ValueMoverAroundSite" (count Pieces of:#1 in:(<Grid:vicinity> #2)))
   (* "ValueEnemyAroundSite" (count Pieces of:(- 3 #1) in:(<Grid:vicinity> #2)))
   (* "ValueEnemyAtSite" (if (= (- 3 #1) (who at:#2)) 1 0)) 
   (* "ValueMoverAtSite" (if (= #1 (who at:#2)) 1 0))
  }
))

(define "Add"
 (do
  (move Add
   (to
    (forEach
     (sites Board)
     if:(< 0 ("NeighborCountOfAt" (mover) (site)))
    )
    (apply
     (and
      {
       (set Var "ReplacedPiece" (who at:(to)))
       (set Var "MaxDistance" ("NeighborCountOfAt" (mover) (to)))
       (remove (to))
       (set Value at:(to) 1) // highlight piece
      }
  ))))
  ifAfterwards:(or
   (!= (mover) (var "ReplacedPiece"))
   (can Move ("Move"))
  )
  (then
   (moveAgain)
)))

(define "Move"
 (do
  (move Add
   (to 
    (forEach
     (sites Empty)
     if:(and
      { 
       (or
        {
         (= (next) (var "ReplacedPiece"))
         (>= 0 ("NeighborCountOfAt" (mover) (site)))
        }
       )
       (>=
        (var "MaxDistance")
        (count Steps 
         (step 
          (to
           if:(or 
            (<Grid:blocking> (next)) 
            (= (site) (from))
         )))
         (site)
         (last To)
       ))
      }
    ))
    (apply (remove (last To)))
  ))
  // capturing piece may not move to a capturable location
  ifAfterwards:(or 
   (!= (next) (var "ReplacedPiece")) 
   (> 0 ("NeighborCountOfAt" (next) (last To)))
)))

(define "MakeADecisionMove"
 (if 
  ("NewTurn")
  ("Add")
  (or
   ("Move")
   (if
    (!= (mover) (var "ReplacedPiece")) //  place or capture without moving
    (move Select (from (last To)) (then (set Value at:(last To) 0)))
   )
   (then
    (and
     (set Score P1 (count Sites in:("SitesOwnedBy" 1))) 
     (set Score P2 (count Sites in:("SitesOwnedBy" 2)))
)))))

//-----------------------------------
// Defining the option for a pie 
(define "PieStatement"
 "The second player sets up the pie offer with two blue pieces then one red piece. Then the first player either starts with Red, or waits and plays Blue."
) 

(define "StartTheGame"
 (if (> 0 (counter)) 
  (or
   {
    (move Add (to (sites Around (sites Outer) if:(no Pieces All in:(sites Around (to) includeSelf:True))))) // (intersection (sites Outer) (union (sites Row (- (count Rows) 1)) (sites Row (- (count Rows) 2))))))
    (move Propose "Start With Pie"
     (then
      (seq
       {
        (note "PieStatement")
        (remove (sites Board))
       }
    )))
   }
  )
  
  (if
   (is Proposed "Start With Pie")
   (if (> 3 (counter))
    (if (> 2 (counter))
     (move Add (to (sites Empty)))
     (move Add (piece (next)) (to (sites Empty)))
     (then (if (> 2 (counter)) (moveAgain)))
    )
    (if (= 3 (counter))
     (or
      (move Swap Players P2 P1)
      ("MakeADecisionMove")
     ) 
     (if (and (was Pass) (= 5 (counter)))
      (move Pass) 
      ("MakeADecisionMove")
   )))
   (if (> 1 (counter))
    (move Add
     (to
      (sites Around (sites Outer) if:(no Pieces All in:(sites Around (to) includeSelf:True)))// (union (sites Row 0) (sites Row 1)))
    ))
    ("MakeADecisionMove")
))))
//---------------------------------------------

(game "Throngs on the Grid" 
 (players 2)
 (equipment  
  {
   <Board:type>
   (piece "Ball" P1 maxValue:1)
   (piece "Ball" P2 maxValue:1)
  }
 )
 (rules 
  (meta (passEnd NoEnd))
  (play
   ("StartTheGame")
  )
  (end
   {
    // Game goes to the end
    (if
     (or
      (all Passed)
      (< 
       (/ (count Vertices) 2)
       (max 0 (max (score P1) (score P2)))
     ))
     (byScore)
    )
   }
)))
 
//------------------
// Influence Scoring

(define "SafeCountOfAt"  
 (+
  // empties have 1/2 the weight
  (* #3
   (size Array
    (array 
     (intersection (<Grid:vicinity> #2) (sites Empty))
  )))
  (* 1  // 1 is 100% save for territory, but slow. 2 assumse players will make defensive moves when isolated groups are attacked.
   (+
    {
     (if (= #1 (who at:#2)) "ValueMoverAtSite" "ValueEnemyAtSite")
     (* "ValueMoverAroundSite" (count Pieces of:#1 in:(<Grid:vicinity> #2)))
     (* "ValueEnemyAroundSite" (count Pieces of:(- 3 #1) in:(<Grid:vicinity> #2)))
    }
))))

(define "SecureStonesOf"
 (forEach
  // Player sites Opponent can't capture as mover
  (sites Occupied by:(player #1)) 
  if:(>= 0 ("SafeCountOfAt" (- 3 #1) (site) "ValueMoverAroundSite"))
))
(define "StonesImmediatelyCapturableBy"
 (forEach  // Opponent sites Player can capture as mover with opponent adding to empties
  (sites Occupied by:(player (- 3 #1))) 
  if:(< 0 ("SafeCountOfAt" #1 (site) "ValueEnemyAroundSite"))
))

(define "SitesUltimatelyReachableFor"
 (forEach
  (sites Board)
  if:(<= Infinity
   (count Steps 
    (step 
     (to
      if:(<Grid:blocking> (- 3 #1)) 
    ))
    (site)
    #2 
))))

(define "SitesOwnedBy"
 (union
  {
   ("SecureStonesOf" #1) 
   ("StonesImmediatelyCapturableBy" #1)
   (difference
    ("SitesUltimatelyReachableFor" (- 3 #1) (sites Occupied by:(player (- 3 #1))))
    ("SitesUltimatelyReachableFor" #1 ("SecureStonesOf" #1))
   )
  }
))

