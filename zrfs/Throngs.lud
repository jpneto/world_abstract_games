(define "LargeBoard" <Grid:largeType>)

(option "Board" <Board> args:{ <type> }
 {
  (item "Small and Plain" <("SmallBoard")> "
  Small Board, 
  Edges as smooth as possible.")
  (item "Large and Plain" <"LargeBoard"> "
  Large Board, 
  Edges as smooth as possible.")
  (item "Small and Spiky" <("SmallBoardSharpTeeth")> "
   Small Board, 
   Edges with sharp spikes that are only secure as end points of secure lines, or part of a triangle or loop."
  )*
  (item "Large and Spiky" <"LargeBoardSharpTeeth"> "
   Large Board, 
   Edges with sharp spikes that are only secure as end points of secure lines, or part of a triangle or loop."
  )
  (item "Small and Knobby" <("SmallBoardDullTeeth")> "
   Small Board, 
   Knobby edges that assist in stabilizing pairs of pieces.
   -- Regular grids (3,4,6,8): Dull cogs.
   -- Snub Grids (5,7): Bulges."
  )
  (item "Large and Knobby" <"LargeBoardDullTeeth"> "
   Large Board, 
   Knobby edges that assist in stabilizing pairs of pieces.
   -- Regular grids (3,4,6,8): Dull cogs.
   -- Snub Grids (5,7): Bulges."
  )
 }
)

(define "GridVicinity"
 (difference
  (sites Around #1 Adjacent)
  (if (= (mover) (who at:(last To))) (sites {(last To)}))
))

(define "CannotCrossConsecutiveOf"
 (or 
  (!= #1 (who at:(from))) 
  (!= #1 (who at:(to)))
))

